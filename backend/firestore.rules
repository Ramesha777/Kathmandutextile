rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated()
        && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated()
        && getUserRole() == 'Manager';
    }

    function isManagerOrAdmin() {
      return isAuthenticated()
        && getUserRole() in ['Manager', 'admin'];
    }

    // ─── users ───
    // Own document: read/write. Admin: read/write any.
    match /users/{userId} {
      allow read, write: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());
    }

    // ─── employees ───
    // Admin: full access. Manager: read only. Punch kiosk: read (for barcode lookup).
    match /employees/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Payment rates (Admin write; Manager read for wage form, orders) ───
    match /rates_machineOperators/{id} {
      allow read: if isAuthenticated() && (isManager() || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /rates_productions/{id} {
      allow read: if isAuthenticated() && (isManager() || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /rates_daily/{id} {
      allow read: if isAuthenticated() && (isManager() || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /rates_selling/{id} {
      allow read: if isAuthenticated() && (isManager() || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // ─── inventory ───
    // Employee: create (add), read. Manager/Admin: update, delete.
    match /inventory/{id} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ─── problem_reports (damage reports) ───
    // Employee: create, read. Manager/Admin: update, delete.
    match /problem_reports/{id} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ─── holidays ───
    // Read: manager + admin. Create: admin (any status); manager only pending leave requests. Updates: admin any; manager cannot change dateFrom/dateTo/status (extend via extendRequest* fields only). Delete: admin only.
    match /holidays/{holidayId} {
      allow read: if isManagerOrAdmin();
      allow create: if isAdmin()
        || (isManager() && request.resource.data.status == 'pending');
      allow update: if isAdmin()
        || (isManager()
            && request.resource.data.status == resource.data.status
            && request.resource.data.dateFrom == resource.data.dateFrom
            && request.resource.data.dateTo == resource.data.dateTo);
      allow delete: if isAdmin();
    }

    // ─── orders ───
    // Employee: create own pending. All auth: read. Manager/Admin: update. Admin: delete.
    match /orders/{orderId} {
      allow create: if isAuthenticated()
        && request.resource.data.status == 'pending'
        && request.resource.data.employeeId == request.auth.uid;

      allow read: if isAuthenticated();

      allow update: if isAuthenticated()
        && (resource.data.employeeId == request.auth.uid
            || isManagerOrAdmin());

      allow delete: if isAdmin();
    }

    // ─── wageEntries ───
    // Manager + Admin: read, create, delete (for wage entry, payslips, performance).
    match /wageEntries/{id} {
      allow read, create, update, delete: if isManagerOrAdmin();
    }

    // ─── punchRecords (barcode punch kiosk: In/Out, daily reset) ───
    // Kiosk (unauthenticated): create and read (for In/Out logic and cooldown). Manager/Admin: read, update. Admin only: delete.
    match /punchRecords/{id} {
      allow create: if true;
      allow read: if true;
      allow update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
